#!name=GLaDOS / Railgun 自动签到
#!desc=GLaDOS / Railgun 自动签到 + 积分兑换（多账号版）
#!date=2026-05-30
#!category=🐹 BOBO Task
#!author=Curtinp118[https://github.com/curtinp118]
#!icon=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Icons/AppIcons/Image/App/GLaDOS.png
#!openUrl=https://glados.vip/
#!arguments=禁用MITM:hostname
#!arguments-desc=禁用MITM：禁用MITM主机名，默认 hostname 表示启用，输入 # 表示禁用。\n\n此脚本获取Cookie会多次触发，导致Surge崩溃设备发热。获取一次Cookie后关闭MITM即可。

[Script]
# > GLaDOS 自动签到
GLaDOS 抓包 = type=http-request, pattern=^https://glados\.network/console/account$, requires-body=0, script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Task/GLaDOS/JS/GLaDOS.js, timeout=10
GLaDOS 抓包2 = type=http-request, pattern=^https://railgun\.info/console/account$, requires-body=0, script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Task/GLaDOS/JS/GLaDOS.js, timeout=10
GLaDOS 抓包3 = type=http-request, pattern=^https://glados\.vip/console/account$, requires-body=0, script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Task/GLaDOS/JS/GLaDOS.js, timeout=10

GLaDOS 签到 = type=cron, cronexp="30 7 * * *", script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Task/GLaDOS/JS/GLaDOS.js, timeout=120

[MITM]
{{{禁用MITM}}} = %APPEND% glados.network, glados.vip, railgun.info
