[Argument]
获取Cookie = switch, ture, tag = [启用]获取Cookie, desc = 关闭开关将不对此选项生效

[Script]
# > PingMe自动化签到
http-request ^https:\/\/api\.pingmeapp\.net\/app\/queryBalanceAndBonus script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Task/PingMe/JS/PingMe.js, tag=PingMe自动签到, enable={获取Cookie}

cron "30 8,20 * * *" script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Task/PingMe/JS/PingMe.js, timeout=10, tag=PingMe自动签到

[MITM]
hostname = api.pingmeapp.net
