[URL Rewrite]
^https?:\/\/surgetool\.com\/?$ - reject

[Script]
binary_test = type=http-request, pattern=^https?:\/\/surgetool\.com\/api\/ping\/binary, requires-body=1, timeout=50, binary-body-mode=1, max-size=-1, script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Surge/Module/NetTest/JS/ntbm.js

crypto_test = type=http-request, pattern=^https?:\/\/surgetool\.com\/api\/test, requires-body=1, timeout=300, max-size=-1, script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Surge/Module/NetTest/JS/nt.js

SPing = type=http-request, pattern=^https?:\/\/surgetool\.com\/api\/ping, requires-body=1, timeout=200, script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Surge/Module/NetTest/JS/api_ping.js

Sfetch = type=http-request, pattern=^https?:\/\/surgetool\.com\/api\/fetch\?url=, requires-body=1, timeout=300, script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Surge/Module/NetTest/JS/Sfetch.js

[MITM]
hostname = %APPEND% surgetool.com
