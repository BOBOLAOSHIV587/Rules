[Rule]
# > 彩云天气 禁用上传信息 - 来源: @苍井灰灰
DOMAIN,gather.colorfulclouds.net,REJECT

# > 插画世界-去开屏广告
DOMAIN,*.adukwai.com,REJECT

[Map Local]
# > ScanScan(BaiMiao)白描解锁黄金会员
^https?:\/\/baimiao\.uzero\.cn\/api\/v2\.user\/c(heckLoginClient|leanAccount) data-type=text data="[]" status-code=200

# > 网易有道词典 翻译 广告均由 安妮 分享 
^https:\/\/dict\.youdao\.com\/course\/tab\/translateTab data-type=text data="{}" status-code=200
# > 听读训练  
^https:\/\/dict\.youdao\.com\/homepage\/tile data-type=text data="{}" status-code=200
# > 首次查词弹窗
^https:\/\/api-overmind\.youdao\.com\/openapi\/get\/luna\/dict\/dict-mobile\/prod\/dictCommonConfig data-type=text data="{}" status-code=200
# > 首页弹窗
^https:\/\/cdke\.youdao\.com\/course3\/recommend\/dict\/startup data-type=text data="{}" status-code=200
# > 搜索预想
^https:\/\/dict\.youdao\.com\/commonsearch data-type=text data="{}" status-code=200
# > 会员优惠券弹窗
^https:\/\/dict\.youdao\.com\/vip\/activity\/couponinfo data-type=text data="{}" status-code=200
# > 首页左上角福利中心
^https:\/\/dict\.youdao\.com\/dictusertask\/system data-type=text data="{}" status-code=200
# > 会员界面横幅广告
^https:\/\/dictvip-business\.youdao\.com\/home\/ad data-type=text data="{}" status-code=200

# > 咪咕视频开屏广告
^https://.*miguvideo\.com/request/sdk data-type=text data=" " status-code=200
^https://common-sc\.miguvideo\.com/task/v7/task-list/cmvideo/visitor data-type=text data=" " status-code=200

# > 咪咕音乐vip、音质、下载
^https://app\.c.nf\.migu\.cn/payment/watch-ad data-type=text data=" " status-code=200

# > 阿里云盘解锁SVIP
https:\/\/api\.(aliyundrive|alipan)\.com\/apps\/v2\/users\/home\/widgets data-type=text data="{}" status-code=200 header="Content-Type:application/json"
https://api.aliyundrive.com/apps/v1/users/home/news data-type=text data=" " status-code=200
https:\/\/api\.alipan\.com\/business\/v1.0\/users\/coupon\/detail data-type=text data=" " status-code=200
https:\/\/member\.alipan\.com\/v1\/users\/onboard_list data-type=text data=" " status-code=200

[URL Rewrite]
# > 芒果TV+去广告,页面优化
^https?://mobile.da.mgtv.com\/m\/page - reject

# > 迅雷Unlock 倍速播放、去广告解锁VIP
^http://adapi\.izuiyou\.com - reject
^https?://api-shoulei-ssl\.xunlei\.com/flowhub/v1/slots:batchGet - reject

# > 咪咕音乐去广告
^https://app\.c\.nf\.migu\.cn/member/api/marketing/text - reject
^https://app\.c\.nf.migu\.cn/strategy/listen-url/v2.5 https://app.c.nf.migu.cn/strategy/listen-url/v2.4 302

# > 阿里云盘解锁SVIP
https:\/\/member\.aliyundrive\.com\/v2\/activity\/sign_in_luckyBottle - reject

[Header Rewrite]
# > Spotify if-none-match返回304状态码
http-request ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/user-customization-service\/v1\/customize$ header-del if-none-match

[Script]
