阿基米德-广播FM解锁Vip = type=http-response, pattern=^https?:\/\/a\.ajmide\.com\/(v21|v29)\/get_user_(detail|home)\.php$, script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/AJiMiDe/JS/AJMD.js, requires-body=true, max-size=-1, timeout=60


