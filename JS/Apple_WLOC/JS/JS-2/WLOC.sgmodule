#!name=ShadowLocPro
#!desc=Apple修改定位；地图选点自动保存到代理工具本地持久化存储，WLOC 脚本直接读取。选点页面: https://shadowloc.ericvip.workers.dev/
#!date=2026-07-11
#!category=🐹 BOBO Enhance
#!author=Mr.Eric[https://t.me/Mr_Alex]
#!icon=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/Apple_WLOC/JS/JS-1/IMG/wloc.png
#!openUrl=https://shadowloc.ericvip.workers.dev/

[Script]
ShadowLocSaveLocation = type=http-request,pattern=^https:\/\/shadowloc\.ericvip\.workers\.dev\/api\/save-location,requires-body=false,timeout=10,script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/Apple_WLOC/JS/JS-2/JS/Surge/ShadowLocSaveLocation.js
ShadowLocStatus = type=http-request,pattern=^https:\/\/shadowloc\.ericvip\.workers\.dev\/api\/location-status,requires-body=false,timeout=10,script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/Apple_WLOC/JS/JS-2/JS/Surge/ShadowLocStatus.js
ShadowLocClear = type=http-request,pattern=^https:\/\/shadowloc\.ericvip\.workers\.dev\/api\/clear-location,requires-body=false,timeout=10,script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/Apple_WLOC/JS/JS-2/JS/Surge/ShadowLocClear.js
ShadowLocPro = type=http-response,pattern=^https:\/\/gs-loc(-cn)?\.apple\.com\/clls\/wloc,requires-body=true,binary-body-mode=true,max-size=0,timeout=30,script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/Apple_WLOC/JS/JS-2/JS/Surge/ShadowLocPro.js

[MITM]
hostname = %APPEND% shadowloc.ericvip.workers.dev, gs-loc.apple.com, gs-loc-cn.apple.com
