#!name=☁️ Cloudflare: 1️⃣ 1.1.1.1 with WARP
#!desc=WARP检测面板与节点提取
#!date=2026-05-31
#!category=🐹 BOBO Premium
#!author=VirgilClyne[https://github.com/VirgilClyne]
#!icon=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/Icons/AppIcons/Image/App/1.1.1.1-01.png
#!openUrl=https://github.com/VirgilClyne/Cloudflare/wiki/☁-1.1.1.1-by-Cloudflare-with-WARP

[Script]
# WARP Panel
generic script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/WARP/JS/1.1.1.1.panel.js, tag=☁ WARP Panel, img-url=lock.icloud.fill, timeout=10
# WARP Personal
http-request ^https?:\/\/(api|zero-trust-client)\.cloudflareclient\.com\/(.*)\/reg\/[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$ script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/WARP/JS/1.1.1.1.request.js, requires-body=1, tag=☁ WARP Personal Request
http-response ^https?:\/\/(api|zero-trust-client)\.cloudflareclient\.com\/(.*)\/reg\/[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$ script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/WARP/JS/1.1.1.1.response.js, requires-body=1, tag=☁ WARP Personal Response
# Zero Trust Client (Cloudflare for Teams)
http-request ^https?:\/\/(api|zero-trust-client)\.cloudflareclient\.com\/(.*)\/reg\/t\.[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$ script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/WARP/JS/1.1.1.1.request.js, requires-body=1, tag=☁ WARP Teams Request
http-response ^https?:\/\/(api|zero-trust-client)\.cloudflareclient\.com\/(.*)\/reg\/t\.[0-9a-f]{8}-[0-9a-f]{4}-[0-5][0-9a-f]{3}-[089ab][0-9a-f]{3}-[0-9a-f]{12}$ script-path=https://raw.githubusercontent.com/BOBOLAOSHIV587/Rules/main/JS/WARP/JS/1.1.1.1.response.js, requires-body=1, tag=☁ WARP Teams Response

[MITM]
hostname = api.cloudflareclient.com, zero-trust-client.cloudflareclient.com
