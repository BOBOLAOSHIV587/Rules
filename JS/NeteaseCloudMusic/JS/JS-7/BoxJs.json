      "id": "WYY_VIP",
      "name": "伪 VIP",
      "keys": [
        "wyy_VipEnabled",
        "wyy_VipLevel",
        "wyy_GrowthValue",
        "wyy_VipExpire"
      ],
      "settings": [
        {
          "id": "wyy_VipEnabled",
          "name": "开启伪 VIP",
          "val": "1",
          "type": "selects",
          "items": [
            { "key": "1", "label": "开启" },
            { "key": "0", "label": "关闭" }
          ],
          "desc": "关闭后所有 VIP 接口透传原响应"
        },
        {
          "id": "wyy_VipLevel",
          "name": "VIP 等级",
          "val": "7",
          "type": "selects",
          "items": [
            { "key": "1", "label": "LV1" },
            { "key": "2", "label": "LV2" },
            { "key": "3", "label": "LV3" },
            { "key": "4", "label": "LV4" },
            { "key": "5", "label": "LV5" },
            { "key": "6", "label": "LV6" },
            { "key": "7", "label": "LV7 (满级)" }
          ],
          "desc": "伪造的 VIP 等级 1-7"
        },
        {
          "id": "wyy_GrowthValue",
          "name": "成长值",
          "val": 99999,
          "type": "number",
          "desc": "VIP 成长值显示 (默认 99999)"
